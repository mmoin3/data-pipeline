    "diag_left[\"SUPP_key\"] = diag_left[\"supp_join_key\"].astype(\"string\").str.strip().str.upper()\n",
    "\n",
    "diag_right[\"FundID_key\"] = diag_right[\"parent_fund\"].astype(\"string\").str.strip().str.upper()\n",
    "diag_right[\"SUPP_key\"] = diag_right[\"supp_join_key\"].astype(\"string\").str.strip().str.upper()\n",
